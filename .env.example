# Data source
SITEMAP_URL=https://pytorch.org/sitemap.xml
URL_PREFIXES=https://pytorch.org/docs/stable
MAX_URLS=60
REQUEST_TIMEOUT=20

# Chunking / retrieval
CHUNK_SIZE=1200
CHUNK_OVERLAP=200
TOP_K=5

# Vector DB
VECTOR_DIR=data/chroma
COLLECTION_NAME=pytorch-docs

# Embeddings provider: openai or ollama
EMBEDDING_PROVIDER=ollama
EMBEDDING_MODEL_OPENAI=text-embedding-3-small
EMBEDDING_MODEL_OLLAMA=nomic-embed-text

# LLM provider: openai or ollama
LLM_PROVIDER=ollama
LLM_MODEL_OPENAI=gpt-4o-mini
LLM_MODEL_OLLAMA=llama3.2

# Keep placeholder; replace only if using OpenAI providers
OPENAI_API_KEY=YOUR_OPENAI_API_KEY
